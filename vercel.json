{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/ícones/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sounds/:path*",
      "destination": "/sounds/:path*"
    },
    {
      "source": "/notificacao.mp3",
      "destination": "/notificacao.mp3"
    },
    {
      "source": "/src/:path*",
      "destination": "/src/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/ícones/:path*",
      "destination": "/ícones/:path*"
    },
    {
      "source": "/style.css",
      "destination": "/style.css"
    },
    {
      "source": "/manifest.json",
      "destination": "/manifest.json"
    },
    {
      "source": "/sw.js",
      "destination": "/sw.js"
    },
    {
      "source": "/baixar",
      "destination": "/baixar.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/checkout",
      "destination": "/checkout.html"
    },
    {
      "source": "/cliente.html",
      "destination": "/cliente.html"
    },
    {
      "source": "/lojas",
      "destination": "/lojas.html"
    },
    {
      "source": "/comandas/:slug",
      "destination": "/garcom.html"
    },
    {
      "source": "/:slug",
      "destination": "/cliente.html"
    }
  ]
}
