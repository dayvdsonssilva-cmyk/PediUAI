{
  "rewrites": [
    { "source": "/restaurante/:slug", "destination": "/pediway.html" },
    { "source": "/(.*)", "destination": "/pediway.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
