// src/modules/ceo.js
// Painel administrativo — acesso restrito ao proprietário da plataforma
// IMPORTANTE: a autenticação do CEO DEVE ser validada no servidor (não aqui).
// Este módulo apenas renderiza os dados após a sessão CEO estar confirmada.

import { supabase } from '../lib/supabase.js'
import { goTo } from './ui.js'

let allStores  = []
let selectedStore = null

// ── Login CEO (via endpoint seguro, não client-side) ──────────────────────
export async function doCeoLogin() {
  const email = document.getElementById('ceo-email')?.value.trim()
  const pass  = document.getElementById('ceo-pass')?.value
  const errEl = document.getElementById('ceo-err')
  if (errEl) errEl.style.display = 'none'

  const res = await fetch('/api/ceo-login', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email, password: pass }),
  })

  if (!res.ok) {
    if (errEl) errEl.style.display = 'block'
    return
  }

  const { token } = await res.json()
  sessionStorage.setItem('ceo_token', token)

  await loadCeoData()
  goTo('s-ceo')
}

// ── Troca de aba CEO ───────────────────────────────────────────────────────
export function switchCeoTab(id) {
  document.querySelectorAll('.ceo-content .tp').forEach(t => t.classList.remove('active'))
  document.querySelectorAll('.ct2').forEach(b => b.classList.remove('active'))
  document.getElementById(id)?.classList.add('active')
  document.querySelectorAll('.ct2').forEach(b => {
    if (b.getAttribute('onclick')?.includes(id)) b.classList.add('active')
  })
}

// ── Carrega todos os dados ────────────────────────────────────────────────
async function loadCeoData() {
  const { data: stores } = await supabase
    .from('stores')
    .select('*')
    .order('created_at', { ascending: false })

  allStores = stores || []

  renderCeoStats()
  renderCeoRecent()
  renderCeoAllStores()
  renderCeoSolicitations()
  renderCeoFinancial()
}

function renderCeoStats() {
  const active  = allStores.filter(s => s.status === 'active').length
  const pending = allStores.filter(s => s.status === 'pending').length
  const mrr     = allStores
    .filter(s => s.status === 'active')
    .reduce((sum, s) => {
      const price = s.plan === 'ultra'
        ? (s.billing === 'annual' ? 79.90 : 99.90)
        : (s.billing === 'annual' ? 29.90 : 39.90)
      return sum + price
    }, 0)

  setEl('ceo-stat-ativos', active)
  setEl('ceo-stat-pend',   pending)
  setEl('ceo-stat-mrr',    `R$ ${mrr.toFixed(0)}`)
  setEl('solic-badge',     pending)
}

function renderCeoRecent() {
  const tbody = document.getElementById('ceo-recent')
  if (!tbody) return
  tbody.innerHTML = allStores.slice(0, 10).map(s => storeRow(s, true)).join('')
}

function renderCeoAllStores() {
  const tbody = document.getElementById('ceo-all-body')
  if (!tbody) return
  tbody.innerHTML = allStores.map(s => storeRow(s, false)).join('')
}

function storeRow(s, simple) {
  const statusBadge = {
    active:   '<span style="color:#1A8A5A;font-weight:700">✓ Ativo</span>',
    pending:  '<span style="color:#B35E0A;font-weight:700">⏳ Pendente</span>',
    inactive: '<span style="color:#C33;font-weight:700">✗ Inativo</span>',
  }[s.status] || s.status

  if (simple) return `<tr>
    <td>${s.name}</td>
    <td>${s.plan || '—'}</td>
    <td>—</td>
    <td>${statusBadge}</td>
    <td><button style="font-size:.7rem" onclick="window.__ceo.openStore('${s.id}')">Ver</button></td>
  </tr>`

  return `<tr>
    <td>${s.name}</td>
    <td style="font-size:.72rem;color:var(--ink3)">${s.email || '—'}</td>
    <td style="font-size:.72rem;font-family:monospace">••••••</td>
    <td>${s.plan || '—'}</td>
    <td>—</td>
    <td>${statusBadge}</td>
    <td style="display:flex;gap:.35rem">
      <button style="font-size:.7rem;padding:.2rem .5rem" onclick="window.__ceo.activate('${s.id}')">Ativar</button>
      <button style="font-size:.7rem;padding:.2rem .5rem;color:#C33" onclick="window.__ceo.suspend('${s.id}')">Suspender</button>
    </td>
  </tr>`
}

function renderCeoSolicitations() {
  const tbody = document.getElementById('ceo-solic-body')
  if (!tbody) return
  const pending = allStores.filter(s => s.status === 'pending')
  tbody.innerHTML = pending.map(s => `<tr>
    <td>${s.name}</td>
    <td style="font-size:.72rem">${s.document || '—'}</td>
    <td style="font-size:.72rem">${s.email || '—'}</td>
    <td>${s.plan || '—'}</td>
    <td style="color:var(--ink3)">—</td>
    <td style="font-size:.72rem">${new Date(s.created_at).toLocaleDateString('pt-BR')}</td>
    <td>
      <button style="font-size:.7rem;background:var(--success-bg);color:var(--success);padding:.2rem .5rem;border:none;border-radius:4px;cursor:pointer"
        onclick="window.__ceo.activate('${s.id}')">✓ Aprovar</button>
    </td>
  </tr>`).join('') || '<tr><td colspan="7" style="text-align:center;color:var(--ink3)">Nenhuma pendência</td></tr>'
}

function renderCeoFinancial() {
  // Placeholder — pode ser expandido com tabela de pagamentos do MP
  setEl('ceo-total-rev', 'R$ —')
  setEl('ceo-mrr2',      'R$ —')
  setEl('ceo-ticket',    'R$ —')
}

export function filterCeoStores(q) {
  const term = q.toLowerCase()
  const filtered = allStores.filter(s =>
    s.name?.toLowerCase().includes(term) || s.email?.toLowerCase().includes(term)
  )
  const tbody = document.getElementById('ceo-all-body')
  if (tbody) tbody.innerHTML = filtered.map(s => storeRow(s, false)).join('')
}

// ── Ações ─────────────────────────────────────────────────────────────────
window.__ceo = {
  async activate(id) {
    await supabase.from('stores').update({ status: 'active' }).eq('id', id)
    await loadCeoData()
  },
  async suspend(id) {
    if (!confirm('Suspender esta loja?')) return
    await supabase.from('stores').update({ status: 'inactive' }).eq('id', id)
    await loadCeoData()
  },
  openStore(id) {
    selectedStore = allStores.find(s => s.id === id)
    if (!selectedStore) return
    const detail = document.getElementById('ceo-store-detail')
    if (detail) {
      setEl('csd-name', selectedStore.name)
      setEl('csd-link', `pediway.com.br/restaurante/${selectedStore.slug || id}`)
      detail.style.display = 'block'
    }
  }
}

function setEl(id, val) {
  const el = document.getElementById(id)
  if (el) el.textContent = val
}
