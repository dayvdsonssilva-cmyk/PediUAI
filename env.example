// src/modules/auth.js
import { supabase } from '../lib/supabase.js'
import { goTo, showNotif, validarCPF, validarCNPJ } from './ui.js'

// ── Login ─────────────────────────────────────────────────────────────────
export async function doLogin() {
  const email = document.getElementById('le')?.value.trim()
  const pass  = document.getElementById('lp')?.value

  clearErr('lerr')

  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    return showErr('lerr', 'E-mail inválido')
  }

  const btn = document.querySelector('#s-login .btn-brand')
  setBtnLoading(btn, true)

  const { data, error } = await supabase.auth.signInWithPassword({ email, password: pass })

  setBtnLoading(btn, false)

  if (error) return showErr('lerr', 'E-mail ou senha incorretos')

  await loadUserSession(data.user)
}

// ── Demo login ────────────────────────────────────────────────────────────
export async function loginDemo() {
  const { data, error } = await supabase.auth.signInWithPassword({
    email: import.meta.env.VITE_DEMO_EMAIL    || 'demo@pediway.com.br',
    password: import.meta.env.VITE_DEMO_PASS  || 'demodemo',
  })
  if (!error) await loadUserSession(data.user)
}

// ── Registro ──────────────────────────────────────────────────────────────
export async function doRegister() {
  const name  = document.getElementById('rn')?.value.trim()
  const doc   = document.getElementById('rdoc')?.value.replace(/\D/g, '')
  const email = document.getElementById('remail')?.value.trim()
  const pass  = document.getElementById('rpass')?.value
  const desc  = document.getElementById('rdesc')?.value.trim()
  const wpp   = document.getElementById('rwpp')?.value.replace(/\D/g, '')

  clearErr('rnerr'); clearErr('rdocerr'); clearErr('remailerr'); clearErr('rpasserr')

  let valid = true
  if (!name) { showErr('rnerr', 'Preencha o nome'); valid = false }

  const docOk = doc.length === 11 ? validarCPF(doc) : validarCNPJ(doc)
  if (!docOk) { showErr('rdocerr', 'CPF ou CNPJ inválido'); valid = false }

  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    showErr('remailerr', 'E-mail inválido'); valid = false
  }
  if (!pass || pass.length < 6) {
    showErr('rpasserr', 'Mínimo 6 caracteres'); valid = false
  }
  if (!valid) return

  const btn = document.querySelector('#s-register .btn-brand')
  setBtnLoading(btn, true)

  const { data, error } = await supabase.auth.signUp({ email, password: pass })

  if (error) {
    setBtnLoading(btn, false)
    return showErr('remailerr', error.message)
  }

  // Salva perfil da loja na tabela stores
  await supabase.from('stores').insert({
    user_id: data.user.id,
    name,
    description: desc,
    document: doc,
    whatsapp: wpp,
    status: 'pending',
  })

  setBtnLoading(btn, false)

  // Avança para a tela de escolha de plano
  goTo('s-payment')
}

// ── Logout ────────────────────────────────────────────────────────────────
export async function fazerLogout() {
  await supabase.auth.signOut()
  goTo('sl')
}

// ── Sessão ao carregar a página ───────────────────────────────────────────
export async function initAuth(onSession) {
  const { data: { session } } = await supabase.auth.getSession()
  if (session?.user) await onSession(session.user)

  supabase.auth.onAuthStateChange(async (_event, session) => {
    if (session?.user) await onSession(session.user)
  })
}

// ── Helpers internos ──────────────────────────────────────────────────────
async function loadUserSession(user) {
  const { data: store } = await supabase
    .from('stores')
    .select('*')
    .eq('user_id', user.id)
    .single()

  if (!store) return goTo('s-payment')

  if (store.status === 'pending') return goTo('s-pending')
  if (store.status === 'inactive') return goTo('s-inactive')

  // Loja ativa — carrega dashboard
  window.__store = store
  import('./dashboard.js').then(m => m.initDashboard(store))
  goTo('s-dash')
}

function showErr(id, msg) {
  const el = document.getElementById(id)
  if (!el) return
  el.textContent = msg
  el.classList.add('show')
}

function clearErr(id) {
  const el = document.getElementById(id)
  if (el) el.classList.remove('show')
}

function setBtnLoading(btn, loading) {
  if (!btn) return
  btn.disabled = loading
  btn.textContent = loading ? 'Aguarde...' : btn.dataset.originalText || btn.textContent
  if (!loading) btn.dataset.originalText = btn.textContent
}
